module Error

(* Error codes *)

type err_t = i64

defn SUCCESS : err_t = 0L
defn EMPTY : err_t = 1L
defn SRC_EMPTY : err_t = 2L
defn DST_OCCUPIED : err_t = 3L
defn INVALID_INDEX : err_t = 4L
defn INVALID_DERIVATION : err_t = 5L
defn INVALID_MONITOR : err_t = 6L
defn INVALID_STATE : err_t = 8L
defn INVALID_PMP : err_t = 9L
defn INVALID_CAPABILITY : err_t = 14L
defn SUSPENDED : err_t = 18L
defn CONTINUE : err_t = -1L