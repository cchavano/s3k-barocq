module Message

import Types

#static
defn set(ks: kstate, send_cap: bool, buf_idx: u64, data0: u64, data1: u64, data2: u64, data3: u64) : kstate =
  let msg = ks.msg in
  let msg = { msg with
    send_cap <- send_cap;
    buf_idx <- buf_idx;
    data0 <- data0;
    data1 <- data1;
    data2 <- data2;
    data3 <- data3;
  } in
  ks.msg <- msg
