module Error

(* Error codes *)

enum err_t {
  Success,
  Empty,
  Src_empty,
  Dst_occupied,
  Invalid_index,
  Invalid_derivation,
  Invalid_monitor,
  Invalid_pid,
  Invalid_state,
  Invalid_pmp,
  Invalid_slot,
  Invalid_socket,
  Invalid_syscall,
  Invalid_register,
  Invalid_capability,
  No_receiver,
  Preempted,
  Timeout,
  Suspended,
  Continue,
}