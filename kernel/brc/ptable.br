module Ptable

import Types

[#static]

#always_inline
defn proc_reg_read(ks: kstate, pid: pid_t, reg: reg_t) : word_t =
  let proc = ks.ptable[pid] in
  match reg with
    case REG_PC => proc.pc
    case REG_RA => proc.ra
    case REG_SP => proc.sp
    case REG_GP => proc.gp
    case REG_TP => proc.tp
    case REG_T0 => proc.t0
    case REG_T1 => proc.t1
    case REG_T2 => proc.t2
    case REG_S0 => proc.s0
    case REG_S1 => proc.s1
    case REG_A0 => proc.a0
    case REG_A1 => proc.a1
    case REG_A2 => proc.a2
    case REG_A3 => proc.a3
    case REG_A4 => proc.a4
    case REG_A5 => proc.a5
    case REG_A6 => proc.a6
    case REG_A7 => proc.a7
    case REG_S2 => proc.s2
    case REG_S3 => proc.s3
    case REG_S4 => proc.s4
    case REG_S5 => proc.s5
    case REG_S6 => proc.s6
    case REG_S7 => proc.s7
    case REG_S8 => proc.s8
    case REG_S9 => proc.s9
    case REG_S10 => proc.s10
    case REG_S11 => proc.s11
    case REG_T3 => proc.t3
    case REG_T4 => proc.t4
    case REG_T5 => proc.t5
    case REG_T6 => proc.t6
    case REG_TPC => proc.tpc
    case REG_TSP => proc.tsp
    case REG_EPC => proc.epc
    case REG_ESP => proc.esp
  end

defn proc_reg_read_noinline(ks: kstate, pid: pid_t, reg: reg_t) : word_t =
  proc_reg_read(ks, pid, reg)

#always_inline
defn proc_reg_write(ks: kstate, pid: pid_t, reg: reg_t, val: word_t) : kstate =
  let ptable = ks.ptable in
  let proc = ptable[pid] in
  let proc =
    match reg with
      case REG_PC => proc.pc <- val
      case REG_RA => proc.ra <- val
      case REG_SP => proc.sp <- val
      case REG_GP => proc.gp <- val
      case REG_TP => proc.tp <- val
      case REG_T0 => proc.t0 <- val
      case REG_T1 => proc.t1 <- val
      case REG_T2 => proc.t2 <- val
      case REG_S0 => proc.s0 <- val
      case REG_S1 => proc.s1 <- val
      case REG_A0 => proc.a0 <- val
      case REG_A1 => proc.a1 <- val
      case REG_A2 => proc.a2 <- val
      case REG_A3 => proc.a3 <- val
      case REG_A4 => proc.a4 <- val
      case REG_A5 => proc.a5 <- val
      case REG_A6 => proc.a6 <- val
      case REG_A7 => proc.a7 <- val
      case REG_S2 => proc.s2 <- val
      case REG_S3 => proc.s3 <- val
      case REG_S4 => proc.s4 <- val
      case REG_S5 => proc.s5 <- val
      case REG_S6 => proc.s6 <- val
      case REG_S7 => proc.s7 <- val
      case REG_S8 => proc.s8 <- val
      case REG_S9 => proc.s9 <- val
      case REG_S10 => proc.s10 <- val
      case REG_S11 => proc.s11 <- val
      case REG_T3 => proc.t3 <- val
      case REG_T4 => proc.t4 <- val
      case REG_T5 => proc.t5 <- val
      case REG_T6 => proc.t6 <- val
      case REG_TPC => proc.tpc <- val
      case REG_TSP => proc.tsp <- val
      case REG_EPC => proc.epc <- val
      case REG_ESP => proc.esp <- val
    end
  in
  let ptable = ptable[pid] <- proc in
  ks.ptable <- ptable

defn proc_reg_write_noinline(ks: kstate, pid: pid_t, reg: reg_t, val: word_t) : kstate =
  proc_reg_write(ks, pid, reg, val)

