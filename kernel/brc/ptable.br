defn proc_state_set(ks: kstate, pid: pid_t, val: u64) : kstate =
  let ptable = ks.ptable in
  let proc = ptable[pid] in
  let proc = proc.state <- val in
  let ptable = ptable[pid] <- proc in
  ks.ptable <- ptable

defn proc_timeout_set(ks: kstate, pid: pid_t, val: word_t) : kstate =
  let ptable = ks.ptable in
  let proc = ptable[pid] in
  let proc = proc.timeout <- val in
  let ptable = ptable[pid] <- proc in
  ks.ptable <- ptable

defn acquire(ks: kstate, pid: pid_t) : kstate =
  let expected = ks.ptable[pid].state in
  let desired = Proc::psf_BUSY in
  if (expected & (Proc::psf_BUSY | Proc::psf_SUSPENDED)) as bool then
    Vreg::write(ks, Vreg::vR0, false as u64)
  else if Machine::time_read(ks.mc) < ks.ptable[pid].timeout then
    Vreg::write(ks, Vreg::vR0, false as u64)
  else
    let ptable = ks.ptable in
    let proc = ptable[pid] in
    let proc = proc.state <- desired in
    let ptable = ptable[pid] <- proc in
    let ks = ks.ptable <- ptable in
    Vreg::write(ks, Vreg::vR0, true as u64)

defn suspend(ks: kstate, pid: pid_t) : kstate =
  let proc = Proc::suspend(ks.ptable[pid]) in
  let ptable = ks.ptable[pid] <- proc in
  ks.ptable <- ptable

defn resume(ks: kstate, pid: pid_t) : kstate =
  let proc = Proc::resume(ks.ptable[pid]) in
  let ptable = ks.ptable[pid] <- proc in
  ks.ptable <- ptable

defn release(ks: kstate, pid: pid_t) : kstate =
  let proc = Proc::release(ks.ptable[pid]) in
  let ptable = ks.ptable[pid] <- proc in
  ks.ptable <- ptable

defn ipc_acquire(ks: kstate, pid: pid_t, chan_idx: u64) : kstate =
  let expected = Proc::psf_BLOCKED | (chan_idx << 48UL) in
  let desired = Proc::psf_BUSY in
  if ks.ptable[pid].state == expected then
    let ks = proc_state_set(ks, pid, desired) in
    let ks = Vreg::write(ks, Vreg::vR0, pid) in
    ks.errcode <- Error::SUCCESS
  else
    ks.errcode <- Error::NO_RECEIVER

defn ipc_wait(ks: kstate, pid: pid_t, chan_idx: u64) : kstate =
  proc_state_set(ks, pid, (chan_idx << 48UL) | Proc::psf_BLOCKED | Proc::psf_BUSY)

defn is_suspended(ks: kstate, pid: pid_t) : bool =
  Proc::is_suspended(ks.ptable[pid])

defn pmp_avail(ks: kstate, pid: pid_t, slot: pmp_slot_t) : bool =
  Proc::pmp_avail(ks.ptable[pid], slot)

defn pmp_load(ks: kstate, pid: pid_t, slot: pmp_slot_t, rwx: pmp_slot_t, addr: napot_t) : kstate =
  let ptable = ks.ptable in
  let proc = ptable[pid] in
  let proc = Proc::pmp_load(proc, slot, rwx, addr) in
  let ptable = ptable[pid] <- proc in
  ks.ptable <- ptable

defn pmp_unload(ks: kstate, pid: pid_t, slot: pmp_slot_t) : kstate =
  let ptable = ks.ptable in
  let proc = ptable[pid] in
  let proc = Proc::pmp_unload(proc, slot) in
  let ptable = ptable[pid] <- proc in
  ks.ptable <- ptable
